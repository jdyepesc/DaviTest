<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="DaviTest Suite" verbose="1" parallel="methods" thread-count="2">

    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="com.davitest.base.AllureListener"/>
    </listeners>

    <test name="Google Search Tests">
        <classes>
            <class name="com.davitest.tests.GoogleSearchTest"/>
        </classes>
    </test>

</suite>
